# Copy to .env.local and fill the value locally. Do not commit .env.local.
RAWG_API_KEY=replace-with-rawg-api-key

# Anthropic API key — used by the local search-provider-server.mjs to power
# the "Why this game?" AI explanation feature. Get yours at console.anthropic.com.
ANTHROPIC_API_KEY=

# Optional: local provider endpoint port.
PLAYSPUTNIK_SEARCH_PORT=4191
# ITAD (IsThereAnyDeal) — free price API, get key at isthereanydeal.com
ITAD_API_KEY=
